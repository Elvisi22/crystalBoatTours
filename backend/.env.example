# Server
PORT=3001
# Comma-separated list of allowed origins for CORS (frontend dev server)
CORS_ORIGIN=http://localhost:5173

# Deposit percentage charged at booking time
DEPOSIT_PERCENT=20

# ── PayPal ─────────────────────────────────────────────────────────────
# Leave blank to run in MOCK mode (no real charges, full flow still works).
# Get credentials at https://developer.paypal.com/dashboard/applications/
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# 'sandbox' for testing, 'live' for real payments
PAYPAL_ENV=sandbox
PAYPAL_CURRENCY=EUR

# ── Booking emails ─────────────────────────────────────────────────────
# Where successful-booking notifications are sent
BOOKING_NOTIFY_EMAIL=info@crystalboattours.com
MAIL_FROM="Crystal Boat Tours <info@crystalboattours.com>"
# SMTP — leave blank to log emails to the console instead of sending
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# ── Admin panel ────────────────────────────────────────────────────────
# Credentials for the /admin dashboard. Pick a strong password before going live.
ADMIN_USERNAME=
ADMIN_PASSWORD=
# Long random string used to sign admin login tokens (e.g. `openssl rand -hex 48`)
JWT_SECRET=
